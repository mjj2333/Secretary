    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
