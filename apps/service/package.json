{
  "name": "@secretary/service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/electron/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && pnpm --filter @secretary/pwa build && node -e \"const {cpSync,rmSync}=require('node:fs');cpSync('server/db/migrations','dist/server/db/migrations',{recursive:true,filter:(s)=>!s.endsWith('.ts')});cpSync('server/prompts','dist/server/prompts',{recursive:true});rmSync('dist/pwa',{recursive:true,force:true});cpSync('pwa/dist','dist/pwa',{recursive:true});cpSync('electron/tray-icon.png','dist/electron/tray-icon.png')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:server": "tsx watch server/index.ts",
    "dev": "electron .",
    "set-secret": "tsx scripts/set-secret.ts",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.3.0",
    "@napi-rs/keyring": "^1.1.7",
    "@secretary/llm-protocol": "workspace:*",
    "@secretary/shared-crypto": "workspace:*",
    "@secretary/shared-types": "workspace:*",
    "better-sqlite3-multiple-ciphers": "^11.5.0",
    "fastify": "^5.1.0",
    "imapflow": "^1.3.4",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "pino": "^9.5.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.0",
    "electron": "^33.2.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
